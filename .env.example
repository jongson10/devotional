# ---- Database (Postgres) ----
DATABASE_URL="postgresql://user:password@host/db?sslmode=require"
DIRECT_URL="postgresql://user:password@host/db?sslmode=require"
# ---- Redis (Vercel KV / Upstash) ----
KV_REST_API_URL="https://your-db.upstash.io"
KV_REST_API_TOKEN="your-read-write-rest-token"
# ---- NextAuth ----
AUTH_SECRET="run: openssl rand -base64 32"
AUTH_URL="https://your-app.vercel.app"
# ---- Email (Resend SMTP) ----
EMAIL_SERVER="smtp://resend:re_YOUR_API_KEY@smtp.resend.com:587"
EMAIL_FROM="Devotional <onboarding@resend.dev>"
# ---- ESV Bible API (Crossway) ----
ESV_API_KEY="your-esv-api-key"
